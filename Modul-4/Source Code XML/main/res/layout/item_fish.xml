<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/spacing_medium"
        android:layout_marginVertical="@dimen/spacing_medium_small"
        app:cardBackgroundColor="@color/card_dark"
        app:cardCornerRadius="@dimen/card_radius"
        app:cardElevation="@dimen/card_elevation"
        app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/spacing_large">

        <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/img_fish"
                android:layout_width="@dimen/img_fish_width"
                android:layout_height="@dimen/img_fish_height"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/RoundedImageStyle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:src="@drawable/cupang"/>

        <TextView
                android:id="@+id/tv_fish_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_large"
                android:textColor="@color/white"
                android:textSize="@dimen/text_xlarge"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:maxLines="2"
                android:ellipsize="end"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/img_fish"
                app:layout_constraintTop_toTopOf="@id/img_fish"
                tools:text="Ikan Cupang"/>

        <TextView
                android:id="@+id/tv_latin_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_large"
                android:layout_marginTop="@dimen/spacing_tiny"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_medium"
                android:textStyle="italic"
                android:fontFamily="sans-serif"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/img_fish"
                app:layout_constraintTop_toBottomOf="@id/tv_fish_name"
                tools:text="Betta splendens"/>

        <TextView
                android:id="@+id/tv_habitat_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_large"
                android:layout_marginTop="@dimen/spacing_medium"
                android:textColor="@color/accent_blue"
                android:textSize="@dimen/text_regular"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/img_fish"
                app:layout_constraintTop_toBottomOf="@id/tv_latin_name"
                tools:text="Habitat:"/>

        <TextView
                android:id="@+id/tv_habitat_value"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_small"
                android:layout_marginTop="@dimen/spacing_medium"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_regular"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/tv_habitat_label"
                app:layout_constraintTop_toBottomOf="@id/tv_latin_name"
                tools:text="Air Tawar"/>

        <TextView
                android:id="@+id/tv_size_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_large"
                android:layout_marginTop="@dimen/spacing_tiny"
                android:textColor="@color/accent_blue"
                android:textSize="@dimen/text_regular"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/img_fish"
                app:layout_constraintTop_toBottomOf="@id/tv_habitat_label"
                tools:text="Ukuran:"/>

        <TextView
                android:id="@+id/tv_size_value"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_small"
                android:layout_marginTop="@dimen/spacing_tiny"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_regular"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/tv_size_label"
                app:layout_constraintTop_toBottomOf="@id/tv_habitat_value"
                tools:text="5 – 7 cm"/>

        <TextView
                android:id="@+id/tv_description_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_large"
                android:layout_marginTop="@dimen/spacing_small"
                android:textColor="@color/accent_blue"
                android:textSize="@dimen/text_regular"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/img_fish"
                app:layout_constraintTop_toBottomOf="@id/tv_size_label"
                tools:text="Deskripsi:"/>

        <TextView
                android:id="@+id/tv_description_value"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_large"
                android:layout_marginTop="@dimen/spacing_tiny"
                android:maxLines="3"
                android:ellipsize="end"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_small"
                android:lineSpacingExtra="@dimen/spacing_tiny"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/img_fish"
                app:layout_constraintTop_toBottomOf="@id/tv_description_label"
                tools:text="Ikan cupang adalah ikan hias air tawar yang terkenal..."/>

        <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_wiki"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="@dimen/btn_height"
                android:layout_marginTop="@dimen/spacing_large_small"
                android:text="@string/btn_wiki"
                android:textColor="@color/accent_blue"
                android:textSize="@dimen/text_regular"
                android:textAllCaps="false"
                app:cornerRadius="@dimen/btn_radius"
                app:strokeColor="@color/accent_blue"
                app:strokeWidth="@dimen/divider_height"
                app:icon="@drawable/ic_open_in_browser"
                app:iconTint="@color/accent_blue"
                app:iconSize="@dimen/icon_size_small"
                app:iconGravity="textStart"
                app:layout_constraintEnd_toStartOf="@id/btn_detail"
                app:layout_constraintHorizontal_chainStyle="spread"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/img_fish"/>

        <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_detail"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="@dimen/btn_height"
                android:layout_marginStart="@dimen/spacing_medium"
                android:layout_marginTop="@dimen/spacing_large_small"
                android:text="@string/btn_detail"
                android:textColor="@color/white"
                android:textSize="@dimen/text_regular"
                android:textAllCaps="false"
                android:backgroundTint="@color/accent_blue"
                app:cornerRadius="@dimen/btn_radius"
                app:icon="@drawable/ic_info"
                app:iconTint="@color/white"
                app:iconSize="@dimen/icon_size_small"
                app:iconGravity="textStart"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/btn_wiki"
                app:layout_constraintTop_toBottomOf="@id/img_fish"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
